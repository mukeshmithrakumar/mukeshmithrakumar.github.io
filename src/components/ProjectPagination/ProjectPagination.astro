---
import { type CollectionEntry } from "astro:content";

import { getProjectUrl } from "@js/projectUtils";

interface Props {
	previousProject?: CollectionEntry<"projects">;
	nextProject?: CollectionEntry<"projects">;
}

const { previousProject, nextProject } = Astro.props as Props;
---

{
	(previousProject || nextProject) && (
		<nav
			class="mt-16 grid grid-cols-1 gap-4 border-t border-base-700 pt-10 md:grid-cols-2"
			aria-label="Project navigation"
		>
			{
				previousProject ? (
					<a
						href={getProjectUrl(previousProject)}
						class="theme-panel group border border-base-700 bg-base-900/60 p-4 transition-colors hover:border-primary-600"
					>
						<p class="text-sm uppercase tracking-[0.2em] text-base-400">Previous project</p>
						<h2 class="mt-3 text-lg font-medium transition-colors group-hover:text-primary-600">
							{previousProject.data.title}
						</h2>
					</a>
				) : (
					<div class="hidden md:block" aria-hidden="true"></div>
				)
			}

			{
				nextProject ? (
					<a
						href={getProjectUrl(nextProject)}
						class="theme-panel group border border-base-700 bg-base-900/60 p-4 text-left transition-colors hover:border-primary-600 md:text-right"
					>
						<p class="text-sm uppercase tracking-[0.2em] text-base-400">Next project</p>
						<h2 class="mt-3 text-lg font-medium transition-colors group-hover:text-primary-600">
							{nextProject.data.title}
						</h2>
					</a>
				) : (
					<div class="hidden md:block" aria-hidden="true"></div>
				)
			}
		</nav>
	)
}

---
/**
 * * These are vertical project item cards
 * Data is taken from the projects content collection
 */

import { type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

// components
import Button from "@components/Button/Button.astro";

interface Props {
	project: CollectionEntry<"projects">;
	showDescription?: boolean;
	rest?: any;
}

const { project, showDescription = true, ...rest } = Astro.props as Props;
const { heroImage, title, description } = project.data;
const href = `/projects/${project.id}/`;
---

<div class="theme-panel flex flex-col p-4" {...rest}>
	<!-- image -->
	<div class="mx-auto max-w-4xl">
		<Image class="object-cover" src={heroImage} alt={title} height={700} />
	</div>

	<!-- text -->
	<div class="mt-4 flex flex-grow flex-col justify-between">
		<div>
			<h2 class="h3">{title}</h2>
			{showDescription && <p class="description mt-4">{description}</p>}
		</div>
		<div class="mt-4 flex">
			<Button variant="ghost" href={href} arrow="right">
				Learn more <span class="sr-only">about {title}</span>
			</Button>
		</div>
	</div>
</div>

---
/**
 * * These are alternating side cards
 * Data is taken from the projects content collection
 */

import { type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

// components
import Button from "@components/Button/Button.astro";

interface Props {
	project: CollectionEntry<"projects">;
	imageSide: "left" | "right";
	showDescription?: boolean;
	rest?: any;
}

const { project, imageSide, showDescription = true, ...rest } = Astro.props as Props;
const { heroImage, title, description } = project.data;
const href = `/projects/${project.id}/`;
---

<div class="mx-auto grid gap-x-8 md:grid-cols-2 md:gap-x-12 lg:gap-x-20" {...rest}>
	<!-- image -->
	<div class=`${imageSide === "right" ? "md:order-last": ""} mx-auto max-w-4xl`>
		<Image class="object-cover" src={heroImage} alt={title} height={700} />
	</div>

	<!-- text -->
	<div>
		<h2 class="h3 mt-6">{title}</h2>
		{showDescription && <p class="description mt-4">{description}</p>}
		<div class="z-20 mt-4 flex">
			<Button variant="ghost" href={href} arrow="right">
				Learn more <span class="sr-only">about {title}</span>
			</Button>
		</div>
	</div>
</div>

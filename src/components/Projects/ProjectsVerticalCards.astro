---
/**
 * * These are alternating side cards with titles, text, and images
 * Recommend using 2 or 3 cards in a row
 */

// components
import ProjectCard from "@components/ProjectCard/ProjectCardVertical.astro";

// utils
import { getAllProjects } from "@js/projectUtils";

interface Props {
	showDescription?: boolean;
}

const { showDescription = true } = Astro.props as Props;
const projects = await getAllProjects();
---

<section id="projects" class="site-container">
	<div class="mx-auto max-w-lg md:max-w-full">
		<div class="mt-20 grid gap-x-4 gap-y-8 md:mt-28 md:grid-cols-2">
			{projects.map((project) => <ProjectCard project={project} showDescription={showDescription} />)}
		</div>
	</div>
</section>

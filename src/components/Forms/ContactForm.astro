---
// components
import Button from "@components/Button/Button.astro";

const formAction = "https://formspree.io/f/mukesh@mukeshmithrakumar.com";
---

<!-- create a contact me form where uses input their name, email, and message -->
<section id="contact" class="mx-auto w-full">
	<div
		id="contact-success"
		class="mb-4 rounded-xl border border-green-500/30 bg-green-500/10 px-4 py-3 text-sm text-green-800 dark:text-green-200"
		hidden
	>
		Your message was sent successfully. I will get back to you soon.
	</div>
	<form
		id="contact-form"
		name="contact form"
		class="mt-4 flex flex-col gap-3"
		action={formAction}
		method="POST"
	>
		<input type="hidden" name="_subject" value="New website contact form submission" />
		<div>
			<div class="grid gap-3 sm:grid-cols-2">
				<div class="flex flex-col">
					<label for="contact-fname" class="opacity-90 dark:opacity-80">First Name</label>
					<input
						type="text"
						class="form__input"
						name="fname"
						pattern="[A-Za-z]+"
						id="contact-fname"
						placeholder="Your first name"
					/>
				</div>

				<div class="flex flex-col">
					<label for="contact-lname" class="opacity-90 dark:opacity-80">Last Name</label>
					<input
						type="text"
						class="form__input"
						name="lname"
						pattern="[A-Za-z]+"
						id="contact-lname"
						placeholder="Your last name"
					/>
				</div>
			</div>
		</div>
		<div>
			<label for="contact-email" class="mb-1 opacity-80">Email </label>
			<input
				type="email"
				class="form__input"
				name="email"
				id="contact-email"
				inputmode="email"
				placeholder="Your preferred contact email"
				required
			/>
		</div>
		<div>
			<label for="contact-message" class="opacity-90 dark:opacity-80">Message </label>
			<textarea
				name="message"
				class="form__input"
				id="contact-message"
				rows="4"
				placeholder="Your message here..."
				required></textarea>
		</div>
		<div class="flex">
			<Button variant="primary" type="submit">Send Message</Button>
		</div>
	</form>
</section>

<script>
	const form = document.querySelector<HTMLFormElement>("#contact-form");
	const successMessage = document.querySelector<HTMLElement>("#contact-success");

	const syncSuccessState = () => {
		const params = new URLSearchParams(window.location.search);
		const sent = params.get("sent") === "true";

		if (successMessage) {
			successMessage.hidden = !sent;
		}

		if (sent) {
			form?.reset();
		}
	};

	window.addEventListener("pageshow", (event) => {
		if (event.persisted) {
			form?.reset();
		}

		syncSuccessState();
	});

	window.addEventListener("beforeunload", () => {
		form?.reset();
	});

	syncSuccessState();
</script>

---
// components
import Button from "@components/Button/Button.astro";

const contactEmail = "newsletter@mukesh.ai";
---

<!-- create a contact me form where uses input their name, email, and message -->
<section id="contact" class="mx-auto w-full">
	<form
		id="contact-form"
		name="contact form"
		class="mt-4 flex flex-col gap-3"
		data-contact-email={contactEmail}
	>
		<div>
			<div class="grid gap-3 sm:grid-cols-2">
				<div class="flex flex-col">
					<label for="contact-fname" class="opacity-90 dark:opacity-80">First Name</label>
					<input
						type="text"
						class="form__input"
						name="fname"
						pattern="[A-Za-z]+"
						id="contact-fname"
						placeholder="Your first name"
					/>
				</div>

				<div class="flex flex-col">
					<label for="contact-lname" class="opacity-90 dark:opacity-80">Last Name</label>
					<input
						type="text"
						class="form__input"
						name="lname"
						pattern="[A-Za-z]+"
						id="contact-lname"
						placeholder="Your last name"
					/>
				</div>
			</div>
		</div>
		<div>
			<label for="contact-email" class="mb-1 opacity-80">Email </label>
			<input
				type="email"
				class="form__input"
				name="email"
				id="contact-email"
				inputmode="email"
				placeholder="Your preferred contact email"
				required
			/>
		</div>
		<div>
			<label for="contact-message" class="opacity-90 dark:opacity-80">Message </label>
			<textarea
				name="message"
				class="form__input"
				id="contact-message"
				rows="4"
				placeholder="Your message here..."
				required></textarea>
		</div>
		<div class="flex">
			<Button variant="primary" type="submit">Send Message</Button>
		</div>
	</form>
</section>

<script>
	const form = document.querySelector<HTMLFormElement>("#contact-form");

	form?.addEventListener("submit", (event) => {
		event.preventDefault();

		const formData = new FormData(form);
		const firstName = String(formData.get("fname") ?? "").trim();
		const lastName = String(formData.get("lname") ?? "").trim();
		const senderEmail = String(formData.get("email") ?? "").trim();
		const message = String(formData.get("message") ?? "").trim();
		const contactEmail = form.dataset.contactEmail;
		const fullName = [firstName, lastName].filter(Boolean).join(" ");

		if (!contactEmail) return;

		const subject = fullName ? `Website contact from ${fullName}` : "Website contact";
		const body = [
			"Hi Mukesh,",
			"",
			message,
			"",
			"Best,",
			fullName || "Website visitor",
			senderEmail || null,
		]
			.filter((line) => line !== null)
			.join("\n");

		window.location.href = `mailto:${contactEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
	});
</script>

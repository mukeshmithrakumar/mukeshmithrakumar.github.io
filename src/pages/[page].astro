---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { type InferGetStaticPropsType } from "astro";
import { Image } from "astro:assets";

// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import Admonition from "@components/Admonition/Admonition.astro";
import Newsletter from "@components/Cta/Newsletter.astro";
import ExternalLink from "@components/MarkdownComponents/ExternalLink.astro";
import MathBlock from "@components/MarkdownComponents/MathBlock.astro";
import MathInline from "@components/MarkdownComponents/MathInline.astro";
import ResultToggle from "@components/MarkdownComponents/ResultToggle.astro";

export async function getStaticPaths() {
	const otherPages: CollectionEntry<"otherPages">[] = await getCollection(
		"otherPages",
		({ data }) => {
			// filter out draft pages
			return data.draft !== true;
		},
	);
	return otherPages.map((page) => ({
		params: { page: page.id },
		props: page,
	}));
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const page = Astro.props as Props;

// convert markdown to html
const { Content } = await render(page);
const { title, description } = page.data;
---

<BaseLayout title={title} description={description}>
	<section class="mx-auto max-w-3xl px-4 pt-36 md:pt-44">
		<h1 class="h1">{title}</h1>
		<div class="text-base-content markdown-content mt-10 max-w-none text-sm md:text-base">
			<Content
				components={{
					a: ExternalLink,
					Admonition,
					Image,
					MathBlock,
					MathInline,
					Newsletter,
					ResultToggle,
				}}
			/>
		</div>
	</section>
</BaseLayout>
